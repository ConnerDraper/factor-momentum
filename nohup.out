#!/bin/bash
#SBATCH --job-name=factor_momentum_style_backtest
#SBATCH --output=logs/factor_momentum_style/50/backtest_%A_%a.out
#SBATCH --error=logs/factor_momentum_style/50/backtest_%A_%a.err
#SBATCH --array=0-29%30
#SBATCH --cpus-per-task=8
#SBATCH --mem=64G
#SBATCH --time=06:00:00
#SBATCH --mail-user=connerd4@byu.edu
#SBATCH --mail-type=BEGIN,END,FAIL

export RAY_ACCEL_ENV_VAR_OVERRIDE_ON_ZERO=0

DATA_PATH="/home/connerd4/silverfund/momentum2/results/full/alphas/factor_momentum_style.parquet"
OUTPUT_DIR="/home/connerd4/silverfund/momentum2/weights/factor_momentum_style/50"
GAMMA="50"
N_CPUS="8"
CONSTRAINTS="ZeroBeta ZeroInvestment"

# Years to process
years=(1995 1996 1997 1998 1999 2000 2001 2002 2003 2004 2005 2006 2007 2008 2009 2010 2011 2012 2013 2014 2015 2016 2017 2018 2019 2020 2021 2022 2023 2024)

num_years=${#years[@]}

if [ $SLURM_ARRAY_TASK_ID -ge $num_years ]; then
    echo "Task ID $SLURM_ARRAY_TASK_ID is out of range (max $((num_years-1)))."
    exit 1
fi

year=${years[$SLURM_ARRAY_TASK_ID]}

source /home/connerd4/silverfund/momentum2/.venv/bin/activate
echo "Running year=$year"
srun python /home/connerd4/silverfund/momentum/.venv/lib/python3.13/site-packages/sf_backtester/scripts/mvo_worker.py \
    --data_path "$DATA_PATH" \
    --gamma "$GAMMA" \
    --year "$year" \
    --output_dir "$OUTPUT_DIR" \
    --n_cpus "$N_CPUS" \
    --constraints $CONSTRAINTS

